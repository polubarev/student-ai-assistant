# API Keys
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default Configuration
DEFAULT_LANGUAGE=ru
DEFAULT_OPENROUTER_MODEL=google/gemini-3-flash-preview

# Optional: OpenRouter Configuration
OPENROUTER_TEMPERATURE=0
OPENROUTER_MAX_TOKENS=
OPENROUTER_TIMEOUT=
OPENROUTER_MAX_RETRIES=2
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Student AI Assistant

# Optional: Transcription Configuration
TRANSCRIPTION_SPEECH_MODEL=universal

# Optional: FFmpeg Configuration
FFMPEG_PATH=ffmpeg

# Optional: Direct browser upload to GCS (large files)
# Must match your Cloud Run public URL, e.g. https://student-ai-assistant-service-xxxxx-uc.a.run.app
APP_BASE_URL=
GCS_SOURCE_BUCKET=
GCS_UPLOAD_BUCKET=
# Optional but recommended for signed browser upload on Cloud Run:
# Set to runtime SA email, e.g. 1234567890-compute@developer.gserviceaccount.com
GCS_SIGNER_SERVICE_ACCOUNT_EMAIL=

LOG_LEVEL=INFO
